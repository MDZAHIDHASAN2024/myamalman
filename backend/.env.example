PORT=5000
MONGODB_URI=mongodb://localhost:27017/my-amal
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
NODE_ENV=development

# ✅ Email Configuration (Forgot Password এর জন্য)
